# Copy this file to .env and fill in your keys
# Never commit .env to git

ANTHROPIC_API_KEY=sk-ant-...

PORT=3000

# --- Client-side: where to find each airline's MCP server ---
# For local demo, these point at the mock servers you run yourself
# (npm run demo:joyair / npm run demo:draair). In production, change
# ONLY these two values to the airline's real hosted MCP endpoint —
# e.g. https://mcp.joyair.com/mcp — and nothing else in the codebase
# needs to change.
JOYAIR_MCP_URL=http://localhost:4001/mcp
DRAAIR_MCP_URL=http://localhost:4002/mcp

# --- Demo-server-side: only relevant if YOU are running the mock ---
# --- airline servers locally for this demo. A real deployment      ---
# --- would never set these, because it wouldn't run these servers. ---
JOYAIR_PORT=4001
DRAAIR_PORT=4002
